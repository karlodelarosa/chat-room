{
  "name": "chatroom",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"wrangler dev --port 8787\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev",
    "dev:node": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250605.0",
    "concurrently": "^9.1.2",
    "wrangler": "^4.19.0"
  }
}
